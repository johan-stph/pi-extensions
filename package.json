{
  "name": "@johan-stph/pi-extensions",
  "version": "1.0.0",
  "description": "Personal pi coding agent extensions",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "lint": "eslint \"**/*.ts\"",
    "build": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run build"
  },
  "pi": {
    "extensions": [
      "./create-mr/index.ts",
      "./start-work/index.ts",
      "./new-work-check/index.ts",
      "./task/index.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
